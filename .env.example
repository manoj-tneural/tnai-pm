# ============================================================
# Custom JWT + PostgreSQL Authentication
# ============================================================

# PostgreSQL Database Connection (used by lib/db.ts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tnai_pm
DB_USER=tnai_user
DB_PASSWORD=tneural123

# JWT Secret for Token Signing and Verification
# IMPORTANT: Generate a strong secret in production!
# Example: openssl rand -base64 32
# Change this value immediately in production - all tokens depend on this secret
JWT_SECRET=your-secret-key-change-in-production

# Next.js Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Migration Notes:
# - This file is for custom JWT + PostgreSQL authentication
# - Supabase is no longer used
# - All auth is handled by lib/db.ts and lib/auth.ts
# - API routes: /api/auth/login, /api/auth/signup, /api/auth/logout
# - Tokens are stored in httpOnly secure cookies
# ============================================================

